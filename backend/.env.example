# ==============================================================================
# JharkhandJobs - Backend Environment Configuration Example
# ==============================================================================
# Copy this file to '.env' and fill in your details.

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Use local MongoDB or MongoDB Atlas URI
MONGO_URI=mongodb://127.0.0.1:27017/jharkhand_jobs

# Authentication
# Secret key for signing JWT tokens (use a long, secure random string in production)
JWT_SECRET=your_jwt_super_secret_key_here
JWT_EXPIRE=7d

# Email SMTP Settings (For notifications, resetting passwords, etc.)
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password_or_app_password

# OAuth & Social Login (Optional)
GOOGLE_CLIENT_ID=your_google_client_id_here
