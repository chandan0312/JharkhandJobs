# ==============================================================================
# JharkhandJobs - Global Gitignore Configuration
# ==============================================================================

# Node.js dependencies
node_modules/
**/node_modules/

# Environment Variables & Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.*.local

# Logs and diagnostics
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log.temp

# Diagnostic/Runtime data
pids
*.pid
*.seed
*.pid.lock

# Build & Compilation Outputs
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.turbo/
**/dist/
**/dist-ssr/

# IDEs, Editors & Workspaces
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history/
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Operating System Files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Backend Specific - Ignored files but keep directories
backend/uploads/resumes/*
!backend/uploads/resumes/.gitkeep
backend/uploads/*
!backend/uploads/resumes/
!backend/uploads/.gitkeep

# Temporary files
myfile
tmp/
temp/
*~
